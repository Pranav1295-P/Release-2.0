# Copy this to .env and fill in the real values
PORT=5001
MONGO_URI=mongodb://localhost:27017/pranav-portfolio
JWT_SECRET=change-this-to-a-long-random-string

# Username that gets isAdmin=true on registration.
# Admins can delete ANY blog post; regular users can delete only their own.
ADMIN_USERNAME=pranav

# CORS — comma-separated list of allowed origins in production
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app

# Public base URL of this backend (used to build PDF download links)
PUBLIC_URL=http://localhost:5001

# ── Email (Resend) — for OTP verification + password reset ──────────────
# Get an API key at https://resend.com → API Keys
# If RESEND_API_KEY is left blank, OTP codes print to the server console
# instead of being emailed (handy for local dev).
RESEND_API_KEY=
# Verified sender. For quick testing you can use: onboarding@resend.dev
EMAIL_FROM=Pranav Murthy <onboarding@resend.dev>

# ── Cloudinary — for image/video uploads on Free-Conversations posts ────
# Get these at https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
