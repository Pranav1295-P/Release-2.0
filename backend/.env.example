# Copy this to .env and fill in the real values
PORT=5000
MONGO_URI=mongodb://localhost:27017/pranav-portfolio
JWT_SECRET=change-this-to-a-long-random-string

# Username that gets isAdmin=true on registration (only this person can publish blog posts)
ADMIN_USERNAME=pranav

# CORS — comma-separated list of allowed origins in production
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app

# Public base URL of this backend (used to build PDF download links)
PUBLIC_URL=http://localhost:5000
